  FindLine "<!-- / tracklist tools menu -->" 6 1
  RegExpReplace "nowrap=\"nowrap\"><span class=\"time\">" "nowrap=\"nowrap\"><span class=\"time\"|"
  FindInLine "nowrap=\"nowrap\"><span class=\"time\"|" 1 1
  OutputTo "VGMDB_TRACK_DURATION_JAP"
  If "<"
    Say "0"
  Else
    SayUntil "</span>"
  EndIf
  FindInLine "nowrap=\"nowrap\"><span class=\"time\"" 1 1
  Do
    If "|<"
      Say "|0"
    Else
      SayUntil "</span>"
    EndIf
    FindInLine "nowrap=\"nowrap\"><span class=\"time\"" 1 1
  While "|"
  Say "|"
EndIf

