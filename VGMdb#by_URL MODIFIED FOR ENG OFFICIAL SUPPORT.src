GoToLine 1
FindLine "<!-- main page contents -->"
OutputTo "VGMDB_BARCODE"
FindLine "<b>Barcode</b>" 1 1
If "<tr>"
  MoveLine 1
  RegExpReplace "<.*?>" ""
  SayRest
EndIf

