  RegExpReplace "<em> / </em>" ""
  RegExpReplace "<span style=\"display:none\"><\/span>" ""
  RegExpReplace "<a.*?>" ""
  RegExpReplace "<\/a.*?>" ""
  RegExpReplace "<span[^>]*?lang=\"en\".*?<\/span>" ""
  RegExpReplace "<span[^>]*?lang=\"ja\".*?<\/span>" ""
  RegExpReplace "<span.*?>" ""
  RegExpReplace "<\/span.*?>" ""
  RegExpReplace "<br \/>" ", "
  Unspace
  SayRest
EndIf

