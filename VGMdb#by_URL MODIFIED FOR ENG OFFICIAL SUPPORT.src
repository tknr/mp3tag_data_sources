RegExpReplace "<a.*?lang=\"ja\".*?>" ""
RegExpReplace "</span>" ""
RegExpReplace "</a>" ""
RegExpReplace "<b>" ""
RegExpReplace "</b>" ""
RegExpReplace "&nbsp;" ""
SayRest

