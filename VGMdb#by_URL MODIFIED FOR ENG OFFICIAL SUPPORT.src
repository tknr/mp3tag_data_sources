###################################################################################################

GoToLine 1
FindLine "<!-- main page contents -->"
OutputTo "VGMDB_CATALOG_NUMBER"
FindLine "<b>Catalog Number</b>" 1 1
MoveLine 1
FindInLine "<td width=\"100%\">" 1 1
If "<"
  FindInLine "<a href=\"#\">" 1 1
  SayUntil "</a>"
Else
  SayRest
EndIf

