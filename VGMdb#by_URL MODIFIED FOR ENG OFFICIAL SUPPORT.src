[Name]=VGMdb
[BasedOn]=vgmdb.net
[SearchBy]=Enter VGMdb album url||%VGMDB_URL%||%s
[UserAgent]=1

# Headings generated with "p_skateb"
# via kammerl.de/ascii/AsciiSignature.php

