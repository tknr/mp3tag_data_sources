# The japanese, romaji and english titles are scraped

# Japanese title

GoToLine 1
FindLine "<!-- main page contents -->"
OutputTo "VGMDB_ALBUM_TITLE_JA"
FindLine "class=\"albumtitle\"" 1 1
Unspace
Replace "<em> / </em>" ""
Replace "|" "/"
FindInLine "lang=\"ja\"" 1 1
FindInLine ">" 1 1
SayUntil "</span"

# Romaji title

GoToLine 1
FindLine "<!-- main page contents -->"
OutputTo "VGMDB_ALBUM_TITLE_JA_LATN"
FindLine "class=\"albumtitle\"" 1 1
Unspace
Replace "<em> / </em>" ""
Replace "|" "/"
FindInLine "lang=\"ja-Latn\"" 1 1
FindInLine ">" 1 1
SayUntil "</span"

# English title

GoToLine 1
FindLine "<!-- main page contents -->"
OutputTo "VGMDB_ALBUM_TITLE_EN"
FindLine "class=\"albumtitle\"" 1 1
Unspace
Replace "<em> / </em>" ""
Replace "|" "/"
FindInLine "lang=\"en\"" 1 1
FindInLine ">" 1 1
SayUntil "</span"

