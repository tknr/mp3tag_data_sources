GoToLine 1
FindLine "<!-- main page contents -->"
OutputTo "VGMDB_MAIN_CREDITS_MUSIC_ORIGINAL"
FindLine "style=\"display:inline\">Music</span>" 1 1
RegExpReplace ".*style=\"display:inline\">Music</span>.*?<td width=\"100%\">" ""
RegExpReplace "</td.*" ""
RegExpReplace "<span style=\"display:none\"><em> / </em></span>" ""
RegExpReplace "<span style=\"color:yellow\" title=\"Uncredited\">\*" ""
RegExpReplace "<a[^>]*>(?!<)" ""
RegExpReplace "<span\b[^>]*\blang=\"en\"[^>]*>.*?</span>" ""
RegExpReplace "<a.*?lang=\"ja\".*?>" ""
RegExpReplace "<span.*?>" ""
RegExpReplace "</span>" ""
RegExpReplace "</a>" ""
SayRest

GoToLine 1
FindLine "<!-- main page contents -->"
OutputTo "VGMDB_MAIN_CREDITS_MUSIC_TRANSLATED"
FindLine "style=\"display:inline\">Music</span>" 1 1
RegExpReplace ".*style=\"display:inline\">Music</span>.*?<td width=\"100%\">" ""
RegExpReplace "</td.*" ""
RegExpReplace "<span style=\"display:none\"><em> / </em></span>" ""
RegExpReplace "<span style=\"color:yellow\" title=\"Uncredited\">\*" ""
RegExpReplace "<a[^>]*>(?!<)" ""
RegExpReplace "<span\b[^>]*\blang=\"ja\"[^>]*>.*?</span>" ""
RegExpReplace "<a.*?lang=\"en\".*?>" ""
RegExpReplace "<span.*?>" ""
RegExpReplace "</span>" ""
RegExpReplace "</a>" ""
SayRest

