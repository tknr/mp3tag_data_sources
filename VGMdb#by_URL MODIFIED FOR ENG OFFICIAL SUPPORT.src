##      ##   ##  ## ##  ##      ##   ##
##   ## ##   ##  ## ##  ##      ##   ##
 #####   #####    ###   ####### ##   ##

#######################################

GoToLine 1
FindLine "<!-- main page contents -->"
OutputTo "COVERURL"
FindLine "id=\"coverart\"" 1 1
Replace "medium-" ""
FindInLine "style=\"background-image: url(" 1 1
If "'"
	MoveChar 1
	SayUntil "'"
Else
	FindInLine "../"
	SayUntil "\""
EndIf

