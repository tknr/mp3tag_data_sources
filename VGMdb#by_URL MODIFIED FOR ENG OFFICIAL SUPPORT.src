IfOutput "VGMDB_TEMP_DISC_EXISTS_8"
  OutputTo "VGMDB_TOTALDISCS"
  Say "8"
Else
  IfOutput "VGMDB_TEMP_DISC_EXISTS_7"
    OutputTo "VGMDB_TOTALDISCS"
    Say "7"
  Else
    IfOutput "VGMDB_TEMP_DISC_EXISTS_6"
      OutputTo "VGMDB_TOTALDISCS"
      Say "6"
    Else
      IfOutput "VGMDB_TEMP_DISC_EXISTS_5"
        OutputTo "VGMDB_TOTALDISCS"
        Say "5"
      Else
        IfOutput "VGMDB_TEMP_DISC_EXISTS_4"
          OutputTo "VGMDB_TOTALDISCS"
          Say "4"
        Else
          IfOutput "VGMDB_TEMP_DISC_EXISTS_3"
            OutputTo "VGMDB_TOTALDISCS"
            Say "3"
          Else
            IfOutput "VGMDB_TEMP_DISC_EXISTS_2"
              OutputTo "VGMDB_TOTALDISCS"
              Say "2"
            Else
              OutputTo "VGMDB_TOTALDISCS"
              Say "1"
            EndIf
          EndIf
        EndIf
      EndIf
    EndIf
  EndIf
EndIf

