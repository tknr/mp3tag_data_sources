###################################################
###################################################

# Available fields
#
# * ALBUM
#   * VGMDB_ALBUM_TITLE_JA
#   * VGMDB_ALBUM_TITLE_JA_LATN
#   * VGMDB_ALBUM_TITLE_EN
#   * VGMDB_CATALOG_NUMBER
#   * VGMDB_BARCODE
#   * VGMDB_RELEASE_DATE
#   * VGMDB_RELEASE_DATE_YEAR
#   * VGMDB_RELEASE_EVENT
#   * VGMDB_MEDIA_FORMAT
#   * VGMDB_CLASSIFICATION
#   * VGMDB_LABEL
#   * VGMDB_MANUFACTURER
#   * VGMDB_DISTRIBUTOR
#   * VGMDB_PUBLISHER
#   * VGMDB_PHONOGRAPHIC_COPYRIGHT
#   * VGMDB_CATEGORY
#   * VGMDB_PRODUCTS_REPRESENTED_EN
#   * VGMDB_PRODUCTS_REPRESENTED_JA
#   * VGMDB_PRODUCTS_REPRESENTED_JA_LATN
#   * VGMDB_NOTES
#   * VGMDB_URL
#
# * CREDITS
#   * VGMDB_MAIN_CREDITS_MUSIC_ORIGINAL
#   * VGMDB_MAIN_CREDITS_MUSIC_TRANSLATED
#   * VGMDB_MAIN_CREDITS_COMPOSER_ORIGINAL
#   * VGMDB_MAIN_CREDITS_COMPOSER_TRANSLATED
#   * VGMDB_MAIN_CREDITS_WRITER_ORIGINAL
#   * VGMDB_MAIN_CREDITS_WRITER_TRANSLATED
#   * VGMDB_MAIN_CREDITS_ARRANGER_ORIGINAL
#   * VGMDB_MAIN_CREDITS_ARRANGER_TRANSLATED
#   * VGMDB_MAIN_CREDITS_PERFORMER_ORIGINAL
#   * VGMDB_MAIN_CREDITS_PERFORMER_TRANSLATED
#   * VGMDB_MAIN_CREDITS_VOCALS_ORIGINAL
#   * VGMDB_MAIN_CREDITS_VOCALS_TRANSLATED
#   * VGMDB_MAIN_CREDITS_LYRICIST_ORIGINAL
#   * VGMDB_MAIN_CREDITS_LYRICIST_TRANSLATED
#   * VGMDB_MAIN_CREDITS_PROGRAMMER_ORIGINAL
#   * VGMDB_MAIN_CREDITS_PROGRAMMER_TRANSLATED
#   * VGMDB_MAIN_CREDITS_CONDUCTOR_ORIGINAL
#   * VGMDB_MAIN_CREDITS_CONDUCTOR_TRANSLATED
#   * VGMDB_MAIN_CREDITS_SOUND_ORIGINAL
#   * VGMDB_MAIN_CREDITS_SOUND_TRANSLATED
#   * VGMDB_MAIN_CREDITS_PRODUCER_ORIGINAL
#   * VGMDB_MAIN_CREDITS_PRODUCER_TRANSLATED
#   * VGMDB_ALL_CREDITS_ORIGINAL
#   * VGMDB_ALL_CREDITS_TRANSLATED
#
# * DISCS
#   * VGMDB_DISC_TITLE
#   * VGMDB_DISC_CLASSIFICATION
#   * VGMDB_DISC_NUMBER
#   * VGMDB_TOTALDISCS
#
# * TRACKS
#   * VGMDB_TRACK_NUMBER_ENGOFF
#   * VGMDB_TRACK_NUMBER_ENG
#   * VGMDB_TRACK_NUMBER_ROM
#   * VGMDB_TRACK_NUMBER_JAP
#   * VGMDB_TRACK_TITLE_ENGOFF
#   * VGMDB_TRACK_TITLE_ENG
#   * VGMDB_TRACK_TITLE_ROM
#   * VGMDB_TRACK_TITLE_JAP
#   * VGMDB_TRACK_DURATION_ENGOFF
#   * VGMDB_TRACK_DURATION_ENG
#   * VGMDB_TRACK_DURATION_ROM
#   * VGMDB_TRACK_DURATION_JAP
#   * VGMDB_TOTALTRACKS

# TOTALDISCS : VGMDB_TOTALDISCS

OutputTo "TOTALDISCS"
IfOutput "VGMDB_TOTALDISCS"
  SayOutput "VGMDB_TOTALDISCS"
EndIf

# TRACK : VGMDB_TRACK_NUMBER_ROM >
#         VGMDB_TRACK_NUMBER_ENGOFF >
#         VGMDB_TRACK_NUMBER_ENG >
#         VGMDB_TRACK_NUMBER_JAP

OutputTo "TRACK"
IfOutput "VGMDB_TRACK_NUMBER_ENGOFF"
  SayOutput "VGMDB_TRACK_NUMBER_ENGOFF"
Else
  IfOutput "VGMDB_TRACK_NUMBER_ENG"
    SayOutput "VGMDB_TRACK_NUMBER_ENG"
  Else
    IfOutput "VGMDB_TRACK_NUMBER_ROM"
      SayOutput "VGMDB_TRACK_NUMBER_ROM"
      Else
        IfOutput "VGMDB_TRACK_NUMBER_JAP"
          SayOutput "VGMDB_TRACK_NUMBER_JAP"
        EndIf
    EndIf
  EndIf
EndIf

# TRACKS : VGMDB_TRACK_TITLE_ROM >
#          VGMDB_TRACK_TITLE_ENGOFF >
#          VGMDB_TRACK_TITLE_ENG >
#          VGMDB_TRACK_TITLE_JAP

OutputTo "TRACKS"
IfOutput "VGMDB_TRACK_TITLE_ENGOFF"
  SayOutput "VGMDB_TRACK_TITLE_ENGOFF"
Else
  IfOutput "VGMDB_TRACK_TITLE_ENG"
    SayOutput "VGMDB_TRACK_TITLE_ENG"
  Else
    IfOutput "VGMDB_TRACK_TITLE_ROM"
      SayOutput "VGMDB_TRACK_TITLE_ROM"
    Else
      IfOutput "VGMDB_TRACK_TITLE_JAP"
        SayOutput "VGMDB_TRACK_TITLE_JAP"
      EndIf
    EndIf
  EndIf
EndIf

# TOTALTRACKS: VGMDB_TOTALTRACKS

RegExpReplace "^.*" "%tracks%"
RegExpReplace "[^|]" ""
Replace "|" "\"|\","
RegExpReplace "^.*" "{\"array\":[${0}]}"
Replace ",]" "]"
json "on" "current"
json_select_many_count "array"
SET "VGMDB_TOTALTRACKS"
OutputTo "VGMDB_TOTALTRACKS"
SayRest
json "off"
OutputTo "TOTALTRACKS"
SayOutput "VGMDB_TOTALTRACKS"

# ALBUM : VGMDB_ALBUM_TITLE_JA_LATN >
#         VGMDB_ALBUM_TITLE_EN >
#         VGMDB_ALBUM_TITLE_JA

OutputTo "ALBUM"
IfOutput "VGMDB_ALBUM_TITLE_EN"
  SayOutput "VGMDB_ALBUM_TITLE_EN"
Else
  IfOutput "VGMDB_ALBUM_TITLE_JA_LATN"
