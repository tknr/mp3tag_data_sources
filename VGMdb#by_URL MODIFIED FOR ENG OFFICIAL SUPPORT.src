######################################################################
######################################################################

# 2.6.2-20250323
# - Fixed an issue with the credit section sometimes containing excess
#   spaces and HTML tags
# --------------------------------------------------------------------
# 2.6.1-20250316
# - TOTALTRACKS is now also written to the default TOTALTRACKS field
#   in addition to VGMDB_TOTALTRACKS
# --------------------------------------------------------------------
# 2.6.0-20250315
# - TOTALTRACKS is enabled again and should display the correct number
#   of tracks across all discs
# --------------------------------------------------------------------
# 2.5.1-20250225
# - Fixed an error if credits are missing entirely on VGMdb
# --------------------------------------------------------------------
# 2.5.0-20250215
# - Code cleanup
# --------------------------------------------------------------------
# 2.4.8-20250105
# - Fixed an error where the disc numbers would not be properly
#   assigned on MacOS
# --------------------------------------------------------------------
# 2.4.7-20250104
# - Fine tuning for the last fix
# - Track numbers are now numbered by disc not total
# - Disabled the default mapping to TOTALTRACKS since it is not
#   accurate on multi disc albums
# --------------------------------------------------------------------
# 2.4.6-20250103
# - Fixed an error leading to the last track of an album being not
#   displayed on MacOS
# --------------------------------------------------------------------
# 2.4.5-20240901
# - Fixed an error when Notes/Description is empty
# --------------------------------------------------------------------
# 2.4.4-20240901
# - Remove HTML tags from Notes/Description (VGMDB_NOTES)
# - Added "Release Event" (VGMDB_RELEASE_EVENT)
# --------------------------------------------------------------------
# 2.4.3-20240816
# - Fixed a few more edgecases with credits
# --------------------------------------------------------------------
# 2.4.2-20240815
# - Fixed credit indicator in ALL_CREDITS sometimes being translated
#   and sometimes being not; this seems to be random behavior by
#   VGMdb...
# --------------------------------------------------------------------
# 2.4.1-20240815
# - Fixed credits containing the "Uncredited" information
# --------------------------------------------------------------------
# 2.4.0-20240815
# - Added original and translated versions of all credits; translated
#   versions are used by default
# --------------------------------------------------------------------
# 2.3.0-20240611
# - Added VGMDB_TOTALTRACKS and VGMDB_TOTALDISCS
# - Added more fields to the default mapping
# --------------------------------------------------------------------
# 2.2.0-20240602
# - Fixed an error when there are no associated products for an album
# - Fixed an error parsing multi-disc albums
# - Added support for the "Music Credit" (VGMDB_MAIN_CREDITS_MUSIC)
# --------------------------------------------------------------------
# 2.1.0-20240125
# - Added support for up to 8 tracklists and up to 8 discs in each
#   tracklist
# --------------------------------------------------------------------
# 2.0.0-20230309
# - Maintenance and code cleanup
# --------------------------------------------------------------------
# 1.1.3-20230212
# - Fixed handling of multiple "VGMDB_PRODUCTS_REPRESENTED_*"
# --------------------------------------------------------------------
# 1.1.2-20230205
# - Fixed regressions with "VGMDB_PRODUCTS_REPRESENTED_*" and
#   "VGMDB_BARCODE"
# - Fixed handling of child menus in "VGMDB_CATALOG_NUMBER"
# --------------------------------------------------------------------
# 1.1.2-20230205
# - Fixed regressions with "VGMDB_PRODUCTS_REPRESENTED_*" and
#   "VGMDB_BARCODE"
# - Fixed handling of child menus in "VGMDB_CATALOG_NUMBER"
# --------------------------------------------------------------------
# 1.1.1-20230204
# - Fixed annotations in "VGMDB_MEDIA_FORMAT"
#   (e. g. "Cactus Data Shield")
# - Fixed error on missing Barcode
# - Fixed "VGMDB_PRODUCTS_REPRESENTED_*" not being picked up when
#   product is the same for all languages and has no special entry
# --------------------------------------------------------------------
# 1.1.0-20230202
# - Replaced "VGMDB_PRODUCTS_REPRESENTED" with
#   "VGMDB_PRODUCTS_REPRESENTED_EN", "VGMDB_PRODUCTS_REPRESENTED_JA"
#   and "VGMDB_PRODUCTS_REPRESENTED_JA_LATN"
# --------------------------------------------------------------------
# 1.0.4-20230201
# - Fixed pipe characters ("|") in album titles
# --------------------------------------------------------------------
# 1.0.3-20230201
# - Fixed indented credits in "VGMDB_ALL_CREDITS"
# --------------------------------------------------------------------
# 1.0.2-20230130
# - Changed default mapping for "GENRE" to favour
#   "VGMDB_DISC_CLASSIFICATION" over "VGMDB_CLASSIFICATION"
# --------------------------------------------------------------------
# 1.0.1-20230127
# - Fixed wrong delimiter in "VGMDB_ALL_CREDITS"
# --------------------------------------------------------------------
# 1.0.0-20230127
# - Initial Release

[ParserScriptAlbum]=...

