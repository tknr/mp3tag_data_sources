GoToLine 1
FindLine "<!-- main page contents -->"
OutputTo "VGMDB_PRODUCTS_REPRESENTED_EN"
FindLine "<b class=\"label\">Products represented</b>" 1 1
FindInLine "<b class=\"label\">Products represented" 1 1
If "</b>"
  MoveLine 1
  RegExpReplace "<\/div>" ""
  RegExpReplace "<em> / </em>" ""
  RegExpReplace "<span style=\"display:none\"><\/span>" ""
  RegExpReplace "<a.*?>" ""
  RegExpReplace "<\/a.*?>" ""
  RegExpReplace "<span[^>]*?lang=\"ja\".*?<\/span>" ""
  RegExpReplace "<span[^>]*?lang=\"ja-Latn\".*?<\/span>" ""
  RegExpReplace "<span.*?>" ""
  RegExpReplace "<\/span.*?>" ""
  RegExpReplace "<br \/>" ", "
  Unspace
  SayRest
EndIf

GoToLine 1
FindLine "<!-- main page contents -->"
OutputTo "VGMDB_PRODUCTS_REPRESENTED_JA"
FindLine "<b class=\"label\">Products represented</b>" 1 1
FindInLine "<b class=\"label\">Products represented" 1 1
If "</b>"
  MoveLine 1
  RegExpReplace "<\/div>" ""
  RegExpReplace "<em> / </em>" ""
  RegExpReplace "<span style=\"display:none\"><\/span>" ""
  RegExpReplace "<a.*?>" ""
  RegExpReplace "<\/a.*?>" ""
  RegExpReplace "<span[^>]*?lang=\"en\".*?<\/span>" ""
  RegExpReplace "<span[^>]*?lang=\"ja-Latn\".*?<\/span>" ""
  RegExpReplace "<span.*?>" ""
  RegExpReplace "<\/span.*?>" ""
  RegExpReplace "<br \/>" ", "
  Unspace
  SayRest
EndIf

GoToLine 1
FindLine "<!-- main page contents -->"
OutputTo "VGMDB_PRODUCTS_REPRESENTED_JA_LATN"
FindLine "<b class=\"label\">Products represented</b>" 1 1
