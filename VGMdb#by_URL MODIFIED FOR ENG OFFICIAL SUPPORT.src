###### ######   #####   #####  ##   ##  #####
  ##   ##   ## ##   ## ##   ## ##   ## ##   ##
  ##   ##   ## ##   ## ##      ##  ##  ##
  ##   ######  ####### ##      #####    #####
  ##   ##   ## ##   ## ##      ##  ##       ##
  ##   ##   ## ##   ## ##   ## ##   ## ##   ##
  ##   ##   ## ##   ##  #####  ##   ##  #####

##############################################
##############################################

# Only the first 8 tracklists are scraped if they are Japanese, Romaji or English
# Even if the first tracklist is not Japanese, Romaji or English it will be used to get the disc information

###### ######   #####   #####  ##   ## ##      #### ##### ######      ####
  ##   ##   ## ##   ## ##   ## ##   ## ##       ## ##   ##  ##         ##
  ##   ##   ## ##   ## ##      ##  ##  ##       ## ##       ##         ##
  ##   ######  ####### ##      #####   ##       ##  #####   ##         ##
  ##   ##   ## ##   ## ##      ##  ##  ##       ##      ##  ##         ##
  ##   ##   ## ##   ## ##   ## ##   ## ##       ## ##   ##  ##         ##
  ##   ##   ## ##   ##  #####  ##   ## ####### #### #####   ##        ####

##########################################################################

 #####  ######  ######          ###### #### #####   #####   #####
##   ## ##   ## ##   ##         ##   ## ## ##   ## ##   ## ##   ##
##   ## ##   ## ##   ##         ##   ## ## ##      ##      ##
####### ##   ## ##   ##         ##   ## ##  #####  ##       #####
##   ## ##   ## ##   ##         ##   ## ##      ## ##           ##
##   ## ##   ## ##   ##         ##   ## ## ##   ## ##   ## ##   ##
##   ## ##   ## ######          ###### #### #####   #####   #####

##################################################################

GoToLine 1
FindLine "<!-- main page contents -->"
FindLine "id=\"tlnav\"" 1 1
FindInLine "#'>" 1 1
If "English (Official)<"
  GoToLine 1
  FindLine "<!-- main page contents -->"
  FindLine "<!-- / tracklist tools menu -->" 1 1
  JoinUntil "</h4></span>"
  RegExpReplace "class=\"smallfont\"><span class=\"label\">" "class=\"smallfont\"><span class=\"label\"|"
  FindInLine "class=\"smallfont\"><span class=\"label\"|" 1 1
  Do
    OutputTo "VGMDB_TRACK_NUMBER_ENGOFF"
    SayUntil "</span>"
    MoveChar -2
    If "0"
      MoveChar 1
    EndIf
    If "0"
      MoveChar 1
    EndIf
    If "0"
      MoveChar 1
    EndIf
    FindInLine "class=\"smallfont\"><span class=\"label\"" 1 1
  While "|"
  OutputTo "VGMDB_TRACK_NUMBER_ENGOFF"
  Say "|"
  GoToLine 1
  FindLine "<!-- main page contents -->"
  FindLine "<!-- / tracklist tools menu -->" 1 1
  RegExpReplace "width=\"100%\" colspan=\"2\">" "width=\"100%\" colspan=\"2\"|"
  FindInLine "width=\"100%\" colspan=\"2\"|" 1 1
  Do
    OutputTo "VGMDB_TRACK_TITLE_ENGOFF"
    SayUntil "</td>"
    FindInLine "width=\"100%\" colspan=\"2\"" 1 1
  While "|"
  Say "|"
  GoToLine 1
  FindLine "<!-- main page contents -->"
  FindLine "<!-- / tracklist tools menu -->" 1 1
  RegExpReplace "nowrap=\"nowrap\"><span class=\"time\">" "nowrap=\"nowrap\"><span class=\"time\"|"
  FindInLine "nowrap=\"nowrap\"><span class=\"time\"|" 1 1
  OutputTo "VGMDB_TRACK_DURATION_ENGOFF"
  If "<"
    Say "0"
  Else
    SayUntil "</span>"
  EndIf
  FindInLine "nowrap=\"nowrap\"><span class=\"time\"" 1 1
  Do
