GoToLine 1
FindLine "<!-- main page contents -->"
OutputTo "VGMDB_RELEASE_DATE"
FindLine "<b>Release Date</b>" 1 1
MoveLine 1
FindInLine "href=\"/db/calendar.php" 1 1
FindInLine "#" 1 1
SayUntil "\">"

GoToLine 1
FindLine "<!-- main page contents -->"
OutputTo "VGMDB_RELEASE_DATE_YEAR"
FindLine "<b>Release Date</b>" 1 1
MoveLine 1
FindInLine "href=\"/db/calendar.php" 1 1
FindInLine "#" 1 1
SayNChars 4

